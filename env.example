# Database Configuration
# Use 'sqlite' for easy setup (default) or 'mysql' for production
DATABASE_TYPE=sqlite

# MySQL Configuration (only needed if DATABASE_TYPE=mysql)
# Replace with your actual MySQL credentials
# DATABASE_URL=mysql://username:password@localhost:3306/timeclock

# Email Configuration (optional - for email reports)
# Get your SendGrid API key from https://sendgrid.com
# SENDGRID_API_KEY=your_sendgrid_api_key_here